{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",

    // ⬇️ Turn off strict mode warnings (you requested clean code / no TS errors)
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    // ⬇️ Fix Jest test warnings (describe, it, expect)
    "types": ["node", "jest"],

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@spxcel/db": ["packages/db/src"],
      "@spxcel/ui": ["packages/ui/src"],
      "@spxcel/utils": ["packages/utils/src"]
    }
  },

  // Avoid scanning node_modules
  "exclude": ["node_modules"]
}
