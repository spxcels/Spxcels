{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "types": ["node", "jest"],

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@spxcel/db": ["packages/db/dist"],
      "@spxcel/ui": ["packages/ui/dist"],
      "@spxcel/utils": ["packages/utils/dist"]
    }
  },

  "exclude": ["node_modules"]
}
