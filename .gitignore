# =====================================================
# Root Monorepo Ignore (Spxcel)
# =====================================================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# PNPM store
.pnpm-store/

# Build output
dist/
build/
out/
.next/
.vercel/output/

# Vite cache
.vite/
*.tsbuildinfo

# Next.js cache
.next/
out/
.next/static/

# TypeScript
*.tsbuildinfo

# Prisma
prisma/generated/
**/generated/
**/*.db
**/*.sqlite
**/*.db-journal

# Environment files
.env
.env.*
!.env.example

# Logs
logs/
*.log
*.log.*
pm2.log

# VSCode / JetBrains
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Lint cache
.eslintcache

# Test coverage
coverage/

# Local database folders
**/migrations/*-dev/
**/migration_lock.toml

# Vercel
.vercel/

# Temporary files
tmp/
temp/
