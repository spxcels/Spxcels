# =====================================================
# Root Monorepo Ignore (Spxcel)
# =====================================================

# -------------------------
# Node / Package Managers
# -------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
.pnpm-store/

# -------------------------
# Build Artifacts
# -------------------------
dist/
build/
out/
.next/
.vercel/output/

# -------------------------
# Caches
# -------------------------
.vite/
.next/
.next/static/
*.tsbuildinfo

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo

# -------------------------
# Prisma (IMPORTANT)
# -------------------------
# Ignore all generated Prisma clients in the monorepo
packages/db/generated/
packages/db/generated/**
**/generated/
prisma/generated/

# Ignore local sqlite or dev databases
**/*.db
**/*.sqlite
**/*.db-journal

# Prisma migration locks
**/migration_lock.toml

# -------------------------
# Environment Files
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# Logs
# -------------------------
logs/
*.log
*.log.*
pm2.log

# -------------------------
# IDE / Editor
# -------------------------
.vscode/
.idea/

# -------------------------
# OS
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Test / Coverage
# -------------------------
coverage/

# -------------------------
# Temporary Files
# -------------------------
tmp/
temp/

# -------------------------
# Nx Cache / Internal
# -------------------------
.nx/cache
.nx/workspace-data

# -------------------------
# Misc Project-Specific
# -------------------------
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
