// ====================================================================
// 📦 Prisma Schema for Spxcel
// FINAL – Clean Card Image + Media Slider Architecture
// ====================================================================

// --------------------------------------------------
// 🧩 Prisma Client Generator
// --------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

// --------------------------------------------------
// 🗄️ Database Connection
// --------------------------------------------------
datasource db {
  provider = "postgresql"
}

// ====================================================================
// 🔐 AUTH & ADMIN
// ====================================================================

model AdminConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("admin_config")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetTokens PasswordResetToken[]

  @@index([email])
  @@map("admins")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  adminId   Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
  @@map("password_reset_tokens")
}

// ====================================================================
// 📱 PHONE DATA STRUCTURE
// ====================================================================

// ---------------------------
// Brand
// ---------------------------
model PhoneBrand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models PhoneModel[]

  @@index([slug])
  @@map("phone_brands")
}

// ---------------------------
// Phone Model
// ⭐ ONE CARD IMAGE PER MODEL
// ---------------------------
model PhoneModel {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  image String? // ⭐ CARD / LISTING IMAGE (ONLY ONE)

  colors   String[]
  variants String[]
  brandId  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand      PhoneBrand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  specs      PhoneSpecs?
  media      PhoneMedia[] // ⭐ ALL SLIDER IMAGES
  affiliates AffiliateLink[]

  @@index([slug])
  @@index([name])
  @@index([brandId])
  @@map("phone_models")
}

// ---------------------------
// Specifications
// ---------------------------
model PhoneSpecs {
  id      Int @id @default(autoincrement())
  modelId Int @unique

  os              String?
  chipset         String?
  cpu             String?
  gpu             String?
  displayType     String?
  displaySize     String?
  resolution      String?
  refreshRate     String?
  protection      String?
  mainCamera      String?
  selfieCamera    String?
  videoRecording  String?
  batteryCapacity String?
  chargingSpeed   String?
  network         String?
  sim             String?
  wifi            String?
  bluetooth       String?
  usb             String?
  sensors         String?
  dimensions      String?
  weight          String?
  buildMaterial   String?
  releaseDate     String?
  otherFeatures   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("phone_specs")
}

// ---------------------------
// Media (⭐ SLIDER ONLY)
// ---------------------------
model PhoneMedia {
  id      Int @id @default(autoincrement())
  modelId Int

  url      String
  publicId String?
  type     MediaType

  order Int? // ⭐ optional slider ordering
  alt   String?

  createdAt DateTime @default(now())

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("phone_media")
}

// ---------------------------
// Affiliate Links
// ---------------------------
model AffiliateLink {
  id        Int      @id @default(autoincrement())
  modelId   Int
  storeName String
  url       String
  price     String?
  currency  String?
  createdAt DateTime @default(now())

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, storeName])
  @@index([modelId])
  @@map("affiliate_links")
}

// ====================================================================
// ENUMS
// ====================================================================

enum MediaType {
  IMAGE
  VIDEO
}
