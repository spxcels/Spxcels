generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth ──────────────────────────────────────────────────────────────

/// Key-value store for runtime admin configuration flags.
model AdminConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("admin_config")
}

/// Admin user with email/password auth and password reset support.
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetTokens PasswordResetToken[]

  @@index([email])
  @@map("admins")
}

/// Short-lived token for admin password reset flows.
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  adminId   Int
  expiresAt DateTime
  /// Prevents replay — token is invalidated after first use.
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
  @@map("password_reset_tokens")
}

// ── Catalog ───────────────────────────────────────────────────────────

/// Top-level phone manufacturer (e.g. Samsung, Apple).
model PhoneBrand {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String   @unique
  /// GSMArena brand slug used to seed automation crawls.
  gsmarenaSlug String?
  /// Override the default specs scrape source for this brand.
  specsSource  String?
  /// Override the default media scrape source for this brand.
  mediaSource  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  models PhoneModel[]

  @@index([slug])
  @@map("phone_brands")
}

/// A specific phone model belonging to a brand.
model PhoneModel {
  id               Int              @id @default(autoincrement())
  name             String
  slug             String           @unique
  brandId          Int
  /// External ID from the scrape source (e.g. GSMArena model ID).
  sourceModelId    String?
  /// Canonical URL of the source page this model was scraped from.
  sourceUrl        String?
  /// When the automation pipeline first found this model.
  discoveredAt     DateTime?
  /// Tracks where this model is in the automation pipeline.
  automationStatus AutomationStatus @default(PENDING)
  /// Available color options for this model (display names).
  colors           String[]
  /// Storage/RAM variant labels (e.g. "8GB/128GB").
  variants         String[]
  /// Primary listing image shown on cards and search results.
  cardImage        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  brand      PhoneBrand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  specs      PhoneSpecs?
  media      PhoneMedia[]
  affiliates AffiliateLink[]

  @@unique([brandId, name])
  @@index([slug])
  @@index([brandId])
  @@index([automationStatus])
  @@map("phone_models")
}

/// Structured specs blob for a phone model, stored as flexible JSON.
/// The JSON shape is defined and validated in the application layer.
model PhoneSpecs {
  id        Int      @id @default(autoincrement())
  modelId   Int      @unique
  specs     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@map("phone_specs")
}

/// A single media asset (image or video) attached to a phone model.
model PhoneMedia {
  id        Int         @id @default(autoincrement())
  modelId   Int
  url       String
  /// Cloudinary public ID — present only for assets managed via Cloudinary.
  publicId  String?
  type      MediaType
  source    MediaSource
  /// Flags the hero image shown when no explicit selection is made.
  isPrimary Boolean     @default(false)
  /// Display order within the model's media gallery.
  order     Int?
  /// Accessible alt text for the asset.
  alt       String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, url])
  @@index([modelId])
  @@index([modelId, order])
  @@map("phone_media")
}

/// Affiliate buy link for a phone model at a specific store.
/// One row per model–store pair; price is refreshed on each sync.
model AffiliateLink {
  id        Int            @id @default(autoincrement())
  modelId   Int
  store     AffiliateStore
  url       String
  /// Latest known price, null if unavailable or not yet fetched.
  price     Decimal?       @db.Decimal(10, 2)
  currency  String         @default("INR")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, store])
  @@index([modelId])
  @@map("affiliate_links")
}

// ── Enums ─────────────────────────────────────────────────────────────

/// Distinguishes between static images and video assets.
enum MediaType {
  IMAGE
  VIDEO
}

/// Indicates where a media asset was originally sourced from.
enum MediaSource {
  OFFICIAL // Brand or manufacturer press assets
  RETAILER // Scraped from a retail product page
  AFFILIATE // Pulled from an affiliate store listing
  USER // Submitted by a user
}

/// Pipeline state for automated spec and media ingestion.
enum AutomationStatus {
  PENDING // Discovered, not yet processed
  PROCESSING // Currently being ingested
  COMPLETE // Successfully ingested
  FAILED // Ingestion failed; inspect logs
}

/// Supported affiliate stores for buy links.
enum AffiliateStore {
  AMAZON
  FLIPKART
}
