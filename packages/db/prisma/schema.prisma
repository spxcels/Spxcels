// ====================================================================
// 📦 Prisma Schema for Spxcel (Optimized & Updated Version)
// ====================================================================

// --------------------------------------------------
// 🧩 Prisma Client Generator
// --------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

// --------------------------------------------------
// 🗄️ Database Connection
// --------------------------------------------------
datasource db {
  provider = "postgresql"
}

// ====================================================================
// 🔐 AUTH & ADMIN
// ====================================================================

model AdminConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("admin_config")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetTokens PasswordResetToken[]

  @@index([email])
  @@map("admins")
}

// --------------------------------------------------
// 🔑 PASSWORD RESET SYSTEM (NEW)
// --------------------------------------------------
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique // secure random 64-char token
  adminId   Int
  expiresAt DateTime // token expiry (15 minutes)
  used      Boolean  @default(false) // prevent reuse
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
  @@map("password_reset_tokens")
}

// ====================================================================
// 📱 PHONE DATA STRUCTURE
// ====================================================================

// ---------------------------
// Brand
// ---------------------------
model PhoneBrand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models PhoneModel[]

  @@index([slug])
  @@map("phone_brands")
}

// ---------------------------
// Model
// ---------------------------
model PhoneModel {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  image     String?
  colors    String[]
  variants  String[]
  brandId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand      PhoneBrand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  specs      PhoneSpecs?
  media      PhoneMedia[]
  affiliates AffiliateLink[]

  @@index([slug])
  @@index([name])
  @@index([brandId])
  @@map("phone_models")
}

// ---------------------------
// Specifications
// ---------------------------
model PhoneSpecs {
  id              Int      @id @default(autoincrement())
  modelId         Int      @unique
  os              String?
  chipset         String?
  cpu             String?
  gpu             String?
  displayType     String?
  displaySize     String?
  resolution      String?
  refreshRate     String?
  protection      String?
  mainCamera      String?
  selfieCamera    String?
  videoRecording  String?
  batteryCapacity String?
  chargingSpeed   String?
  network         String?
  sim             String?
  wifi            String?
  bluetooth       String?
  usb             String?
  sensors         String?
  dimensions      String?
  weight          String?
  buildMaterial   String?
  releaseDate     String?
  otherFeatures   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("phone_specs")
}

// ---------------------------
// Media
// ---------------------------
model PhoneMedia {
  id        Int       @id @default(autoincrement())
  modelId   Int
  url       String
  publicId  String?
  type      MediaType
  alt       String?
  width     Int?
  height    Int?
  duration  Float?
  createdAt DateTime  @default(now())

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("phone_media")
}

// ---------------------------
// Affiliate Links
// ---------------------------
model AffiliateLink {
  id        Int      @id @default(autoincrement())
  modelId   Int
  storeName String
  url       String
  price     String?
  currency  String?
  createdAt DateTime @default(now())

  model PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, storeName])
  @@index([modelId])
  @@map("affiliate_links")
}

// ====================================================================
// Enums
// ====================================================================
enum MediaType {
  IMAGE
  VIDEO
}
