// ====================================================================
// 📦 Prisma Schema for Spxcel
// Docs: https://pris.ly/d/prisma-schema
// ====================================================================

// --------------------------------------------------
// 🧩 Prisma Client Generator
// --------------------------------------------------
// Output is redirected into /dist to support monorepo
// (Next.js / Vercel require runtime JS, not TS source)
// --------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

// --------------------------------------------------
// 🗄️ Database Connection
// --------------------------------------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================================================
// 🔐 AUTH & ADMIN
// ====================================================================

// Admin configuration (Dynamic key-value store)
model AdminConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// Admin user
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String // hashed password
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ====================================================================
// 📱 PHONES: Brands, Models, Specs, Media, Affiliate Links
// ====================================================================

// Brand (Samsung, Apple, Xiaomi, etc.)
model PhoneBrand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models PhoneModel[]
}

// --------------------------------------------------
// Phone Model (Samsung S24, iPhone 16, etc.)
// --------------------------------------------------
model PhoneModel {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  image     String?
  colors    String[]
  variants  String[]
  brandId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand      PhoneBrand      @relation(fields: [brandId], references: [id])
  specs      PhoneSpecs?
  media      PhoneMedia[]
  affiliates AffiliateLink[]
}

// --------------------------------------------------
// Detailed Specifications
// --------------------------------------------------
model PhoneSpecs {
  id              Int      @id @default(autoincrement())
  modelId         Int      @unique
  os              String?
  chipset         String?
  cpu             String?
  gpu             String?
  displayType     String?
  displaySize     String?
  resolution      String?
  refreshRate     String?
  protection      String?
  mainCamera      String?
  selfieCamera    String?
  videoRecording  String?
  batteryCapacity String?
  chargingSpeed   String?
  network         String?
  sim             String?
  wifi            String?
  bluetooth       String?
  usb             String?
  sensors         String?
  dimensions      String?
  weight          String?
  buildMaterial   String?
  releaseDate     String?
  otherFeatures   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  model PhoneModel @relation(fields: [modelId], references: [id])
}

// --------------------------------------------------
// Media (Images / Videos)
// --------------------------------------------------
model PhoneMedia {
  id        Int       @id @default(autoincrement())
  modelId   Int
  url       String
  publicId  String?
  type      MediaType
  alt       String?
  width     Int?
  height    Int?
  duration  Float?
  createdAt DateTime  @default(now())

  model PhoneModel @relation(fields: [modelId], references: [id])
}

// --------------------------------------------------
// Affiliate Links (Amazon, Flipkart, etc.)
// --------------------------------------------------
model AffiliateLink {
  id        Int      @id @default(autoincrement())
  modelId   Int
  storeName String
  url       String
  price     String?
  currency  String?
  createdAt DateTime @default(now())

  model PhoneModel @relation(fields: [modelId], references: [id])
}

// --------------------------------------------------
// Enums
// --------------------------------------------------
enum MediaType {
  IMAGE
  VIDEO
}
