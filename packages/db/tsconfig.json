{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    // Required to generate index.d.ts
    "declaration": true,
    "emitDeclarationOnly": false,

    "rootDir": "src",
    "outDir": "dist",

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },

  // Only include TypeScript source
  "include": ["src"]
}
