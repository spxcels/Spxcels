{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    // Node types so fs/path/url work
    "types": ["node"],

    // Required to generate index.d.ts
    "declaration": true,
    "emitDeclarationOnly": false,

    "rootDir": ".",
    "outDir": "dist",

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },

  "include": [
    "src",
    "prisma"
  ]
}