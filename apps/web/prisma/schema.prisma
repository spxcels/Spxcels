// Prisma Client Generator
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL Database Connection
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// 📱 PHONE BRAND MODEL
// =========================
model PhoneBrand {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  models    PhoneModel[]
}

// =========================
// 📱 PHONE MODEL
// =========================
model PhoneModel {
  id         Int             @id @default(autoincrement())
  name       String
  slug       String          @unique
  image      String?
  colors     String[]
  variants   String[]
  brandId    Int
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  // Relations
  brand      PhoneBrand      @relation(fields: [brandId], references: [id])
  specs      PhoneSpecs?
  media      PhoneMedia[]
  affiliates AffiliateLink[]
}

// =========================
// ⚙️ PHONE SPECIFICATIONS
// =========================
model PhoneSpecs {
  id              Int        @id @default(autoincrement())
  modelId         Int        @unique
  os              String?
  chipset         String?
  cpu             String?
  gpu             String?
  displayType     String?
  displaySize     String?
  resolution      String?
  refreshRate     String?
  protection      String?
  mainCamera      String?
  selfieCamera    String?
  videoRecording  String?
  batteryCapacity String?
  chargingSpeed   String?
  network         String?
  sim             String?
  wifi            String?
  bluetooth       String?
  usb             String?
  sensors         String?
  dimensions      String?
  weight          String?
  buildMaterial   String?
  releaseDate     String?
  otherFeatures   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relation
  model           PhoneModel @relation(fields: [modelId], references: [id])
}

// =========================
// 🖼️ PHONE MEDIA (Images / Videos) for Cloudinary
// =========================
model PhoneMedia {
  id         Int        @id @default(autoincrement())
  modelId    Int
  url        String       // Cloudinary URL
  publicId   String?      // Cloudinary public ID for updates/deletes
  type       MediaType
  alt        String?      // Image alt text
  width      Int?         // optional width
  height     Int?         // optional height
  duration   Float?       // optional (for videos)
  createdAt  DateTime     @default(now())

  // Relation
  model      PhoneModel   @relation(fields: [modelId], references: [id])
}

// =========================
// 💸 AFFILIATE LINKS
// =========================
model AffiliateLink {
  id        Int        @id @default(autoincrement())
  modelId   Int
  storeName String
  url       String
  price     String?
  currency  String?
  createdAt DateTime   @default(now())

  // Relation
  model     PhoneModel @relation(fields: [modelId], references: [id])
}

// =========================
// 🗂️ ENUMS
// =========================
enum MediaType {
  IMAGE
  VIDEO
}