{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "target": "ES2020",

    "lib": ["dom", "dom.iterable", "es2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,

    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,

    "jsx": "react-jsx",

    "incremental": true,
    "plugins": [{ "name": "next" }],

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],

      /* FIXED — NEVER point prisma to dist */
      "@spxcel/db": ["../../packages/db"],
      "@spxcel/db/*": ["../../packages/db/*"]
    }
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
