{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "target": "ES2022",

    "module": "Node16",
    "moduleResolution": "Node16",

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "sourceMap": true,
    "declaration": true,

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],

    "types": [
  "node",
  "express",
  "multer"
]
  },

  "include": [
    "src/**/*"
  ]
}