{
  "name": "spxcel",
  "private": true,
  "version": "1.0.0",

  "engines": {
    "node": "20.11.1"
  },

  "scripts": {
    "dev": "pnpm -F web dev",
    "build": "pnpm -F web build",
    "lint": "pnpm -F web lint || true",
    "prisma": "pnpm -F @spxcel/db prisma",
    "generate": "pnpm -F @spxcel/db generate",
    "migrate": "pnpm -F @spxcel/db migrate",
    "studio": "pnpm -F @spxcel/db studio"
  },

  "workspaces": [
    "apps/*",
    "packages/*"
  ],

  "devDependencies": {
    "@types/jest": "^30.0.0",
    "nx": "22.1.3"
  },

  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  }
}
