{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "lib": ["ES2020"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/admin-frontend/src/*"],

      "@spxcel/ui": ["packages/ui/src"],
      "@spxcel/ui/*": ["packages/ui/src/*"],

      "@spxcel/db": ["packages/db/dist"],
      "@spxcel/utils": ["packages/utils/dist"]
    }
  }
}
